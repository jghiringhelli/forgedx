{
  "name": "@forgedx/cli",
  "version": "0.1.0",
  "description": "ForgeDX CLI — GS Readiness Diagnostic tool",
  "type": "module",
  "bin": {
    "forgedx": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "scan": "tsx src/index.ts scan",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@forgedx/core": "workspace:*",
    "@inquirer/prompts": "^7.0.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}
